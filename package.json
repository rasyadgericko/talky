{
  "name": "talky",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:compile": "tsc -p electron/tsconfig.json",
    "electron:dev": "npm run build && npm run electron:compile && electron .",
    "electron:build": "npm run build && npm run electron:compile && node scripts/prepare-electron.mjs && electron-builder --mac",
    "electron:build:win": "npm run build && npm run electron:compile && node scripts/prepare-electron.mjs && electron-builder --win"
  },
  "dependencies": {
    "@picovoice/porcupine-web": "^3.0.0",
    "@picovoice/web-voice-processor": "^4.0.0",
    "@xenova/transformers": "^2.17.2",
    "electron-updater": "^6.3.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
